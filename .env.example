# Distill Environment Variables Schema
# DO NOT ADD SECRETS TO THIS FILE

# --- Core Settings ---
NODE_ENV=development
API_KEYS_ENABLED=true

# --- Gateway ---
GATEWAY_PORT=3000

# --- Auth Service ---
AUTH_SERVICE_PORT=3001
AUTH_DB_URL="postgresql://${AUTH_DB_USER}:${AUTH_DB_PASS}@localhost:5432/auth_db"
JWT_SECRET="generate-es256-key-here"
OIDC_ISSUER_URL="https://your-tenant.okta.com/oauth2/default"
OIDC_CLIENT_ID="your_client_id"
OIDC_CLIENT_SECRET="your_client_secret"

# --- Document Service ---
DOCUMENT_SERVICE_PORT=3002
DOCUMENT_DB_URL="postgresql://${DOCUMENT_DB_USER}:${DOCUMENT_DB_PASS}@localhost:5433/document_db"
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
AWS_ACCESS_KEY_ID="minioadmin"
AWS_SECRET_ACCESS_KEY="minioadmin"
AWS_REGION="us-east-1"
S3_ENDPOINT="http://localhost:9000"
S3_BUCKET="distill-documents"

# --- Extraction Service ---
EXTRACTION_SERVICE_PORT=3003
EXTRACTION_DB_URL="postgresql://${EXTRACTION_DB_USER}:${EXTRACTION_DB_PASS}@localhost:5435/extraction_db"
GEMINI_API_KEY="your_gemini_key"
OPENAI_API_KEY="your_openai_key"
ANTHROPIC_API_KEY="your_anthropic_key"
AI_PROVIDER_ORDER="gemini,openai,anthropic"

# --- Validation Service ---
VALIDATION_SERVICE_PORT=3004

# --- Review Service ---
REVIEW_SERVICE_PORT=3005
REVIEW_DB_URL="postgresql://${REVIEW_DB_USER}:${REVIEW_DB_PASS}@localhost:5434/review_db"

# --- Analytics Service ---
ANALYTICS_SERVICE_PORT=3006
ANALYTICS_DB_URL="postgresql://${ANALYTICS_DB_USER}:${ANALYTICS_DB_PASS}@localhost:5436/analytics_db"

# --- Notification Service ---
NOTIFICATION_SERVICE_PORT=3007

# --- Postgres Databases ---
# Use distinct users/passwords for each service in production
AUTH_DB_USER=auth_user
AUTH_DB_PASS=auth_password
DOCUMENT_DB_USER=document_user
DOCUMENT_DB_PASS=document_password
REVIEW_DB_USER=review_user
REVIEW_DB_PASS=review_password
EXTRACTION_DB_USER=extraction_user
EXTRACTION_DB_PASS=extraction_password
ANALYTICS_DB_USER=analytics_user
ANALYTICS_DB_PASS=analytics_password

# --- Message Broker ---
RABBITMQ_ADMIN_USER=admin
RABBITMQ_ADMIN_PASS=admin_password
RMQ_DOC_PASS=doc_password
RMQ_EXT_PASS=ext_password
RMQ_VAL_PASS=val_password
RMQ_REV_PASS=rev_password
RABBITMQ_URL="amqp://admin:admin_password@localhost:5672"

# --- Cache ---
REDIS_PASSWORD=redis_password
REDIS_URL="redis://:redis_password@localhost:6379"

# --- Web (Frontend) ---
VITE_API_URL="http://localhost:3000/api"
VITE_WS_URL="ws://localhost:3007"
