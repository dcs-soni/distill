{
  "users": [
    {
      "name": "admin",
      "password": "${RABBITMQ_ADMIN_PASS}",
      "tags": "administrator"
    },
    {
      "name": "document_service",
      "password": "${RMQ_DOC_PASS}",
      "tags": ""
    },
    {
      "name": "extraction_service",
      "password": "${RMQ_EXT_PASS}",
      "tags": ""
    },
    {
      "name": "validation_service",
      "password": "${RMQ_VAL_PASS}",
      "tags": ""
    },
    {
      "name": "review_service",
      "password": "${RMQ_REV_PASS}",
      "tags": ""
    }
  ],
  "vhosts": [
    {
      "name": "distill"
    }
  ],
  "permissions": [
    {
      "user": "admin",
      "vhost": "distill",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    },
    {
      "user": "document_service",
      "vhost": "distill",
      "configure": "^(document\\.|extraction\\.document\\.|dlx\\.).*",
      "write": "^(document\\.|dlx\\.).*",
      "read": "^(document\\.|extraction\\.document\\.|dlx\\.).*"
    },
    {
      "user": "extraction_service",
      "vhost": "distill",
      "configure": "^(extraction\\.|validation\\.extraction\\.|dlx\\.).*",
      "write": "^(extraction\\.|dlx\\.).*",
      "read": "^(extraction\\.|validation\\.extraction\\.|dlx\\.).*"
    },
    {
      "user": "validation_service",
      "vhost": "distill",
      "configure": "^(validation\\.|review\\.validation\\.|dlx\\.).*",
      "write": "^(validation\\.|dlx\\.).*",
      "read": "^(validation\\.|review\\.validation\\.|dlx\\.).*"
    },
    {
      "user": "review_service",
      "vhost": "distill",
      "configure": "^(review\\.|dlx\\.).*",
      "write": "^(review\\.|dlx\\.).*",
      "read": "^(review\\.|dlx\\.).*"
    }
  ],
  "parameters": [],
  "policies": [
    {
      "vhost": "distill",
      "name": "ha-all",
      "pattern": ".*",
      "definition": {
        "ha-mode": "all",
        "ha-sync-mode": "automatic"
      }
    },
    {
      "vhost": "distill",
      "name": "queue-limits",
      "pattern": ".*",
      "definition": {
        "max-length": 10000,
        "message-ttl": 86400000
      }
    }
  ],
  "exchanges": [
    {
      "name": "document.exchange",
      "vhost": "distill",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "extraction.exchange",
      "vhost": "distill",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "validation.exchange",
      "vhost": "distill",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "review.exchange",
      "vhost": "distill",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "dlx.exchange",
      "vhost": "distill",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    }
  ],
  "queues": [
    {
      "name": "extraction.document.uploaded",
      "vhost": "distill",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange": "dlx.exchange",
        "x-dead-letter-routing-key": "extraction.document.uploaded"
      }
    },
    {
      "name": "validation.extraction.completed",
      "vhost": "distill",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange": "dlx.exchange",
        "x-dead-letter-routing-key": "validation.extraction.completed"
      }
    },
    {
      "name": "review.validation.needs_review",
      "vhost": "distill",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange": "dlx.exchange",
        "x-dead-letter-routing-key": "review.validation.needs_review"
      }
    },
    {
      "name": "dead.letter.queue",
      "vhost": "distill",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "bindings": [
    {
      "source": "document.exchange",
      "vhost": "distill",
      "destination_type": "queue",
      "destination": "extraction.document.uploaded",
      "routing_key": "document.uploaded.*",
      "arguments": {}
    },
    {
      "source": "extraction.exchange",
      "vhost": "distill",
      "destination_type": "queue",
      "destination": "validation.extraction.completed",
      "routing_key": "extraction.completed.*",
      "arguments": {}
    },
    {
      "source": "validation.exchange",
      "vhost": "distill",
      "destination_type": "queue",
      "destination": "review.validation.needs_review",
      "routing_key": "validation.needs_review.*",
      "arguments": {}
    },
    {
      "source": "dlx.exchange",
      "vhost": "distill",
      "destination_type": "queue",
      "destination": "dead.letter.queue",
      "routing_key": "#",
      "arguments": {}
    }
  ]
}
