{
  "name": "distill-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Distill — Enterprise Financial Data Extraction Platform",
  "workspaces": [
    "gateway",
    "services/*",
    "web",
    "shared/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "scaffold": "bash ./scripts/scaffold-service.sh",
    "prepare": "husky",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml}\""
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  }
}
