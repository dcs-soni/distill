{
  "name": "@distill/auth-service",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/bootstrap.ts",
    "build": "tsc",
    "start": "node dist/services/auth-service/src/bootstrap.js",
    "pretest": "npx prisma generate",
    "test": "vitest run tests/unit",
    "test:unit": "vitest run tests/unit",
    "test:integration": "npx dotenv-cli -e .env.test -- vitest run tests/integration",
    "pretest:integration": "npx dotenv-cli -e .env.test -- npx prisma migrate deploy",
    "test:coverage": "npx dotenv-cli -e .env.test -- vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "pretypecheck": "npx prisma generate",
    "prebuild": "npx prisma generate",
    "prelint": "npx prisma generate"
  },
  "dependencies": {
    "@distill/types": "*",
    "@distill/utils": "*",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@prisma/client": "^5.12.1",
    "amqplib": "^0.10.3",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "ioredis": "^5.10.1",
    "jose": "^4.15.9",
    "openid-client": "^5.7.1",
    "pino": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/node": "^20.12.7",
    "@vitest/coverage-v8": "^1.6.1",
    "prisma": "^5.12.1",
    "tsx": "^4.7.2",
    "typescript": "^6.0.3",
    "vitest": "^1.5.0"
  }
}
