{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@distill/types": ["./shared/types/src/index.ts"],
      "@distill/types/*": ["./shared/types/src/*"],
      "@distill/utils": ["./shared/utils/src/index.ts"],
      "@distill/utils/*": ["./shared/utils/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
